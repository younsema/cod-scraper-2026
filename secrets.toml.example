# ---------------------------------------------------------------------------
# هذا مثال فقط. لا ترفع ملف secrets.toml الحقيقي إلى GitHub أبداً.
#
# فـ استعمال محلي (على جهازك): سمي هاد الملف "secrets.toml" (بدون .example)
# وحطو فـ نفس المجلد .streamlit/
#
# فـ Streamlit Cloud: ماخصكش ترفع أي ملف. غير دخل لـ:
# Settings > Secrets > حط المحتوى التالي وبدلو بالأكواد والقيم ديالك
# ---------------------------------------------------------------------------

[keys]
# max_uses هنا كتطبق فعليا عبر usage_tracker.py — 0 يعني بلا حدود
"TEST-FREE-00" = { type = "trial", expires = "2026-12-31", max_uses = 20 }
"CLIENT-EXEMPLE-01" = { type = "paid", expires = "", max_uses = 0 }

[supabase]
# خاصك تشغل supabase_setup.sql مرة وحدة فـ Supabase > SQL Editor قبل هادشي
# القيم هادو كتلقاهم فـ Supabase > Settings > API
url = "https://xxxxxxxxxxxx.supabase.co"
key = "eyJhbGciOi....."   # استعمل service_role key، ماشي anon key
